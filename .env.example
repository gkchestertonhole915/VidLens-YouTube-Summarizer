# 复制为 .env 并填入阿里云百炼(DashScope) 的 key:  https://bailian.console.aliyun.com/
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx

# 可选：模型覆盖
VIDLENS_LLM_MODEL=qwen-plus
VIDLENS_VL_MODEL=qwen-vl-max
VIDLENS_ASR_MODEL=paraformer-realtime-v2

# —— 绕过 YouTube "确认你不是机器人" 反爬，二选一 ——
# 方式A(推荐)：直接从已登录 YouTube 的浏览器读 cookies，填浏览器名
# VIDLENS_COOKIES_FROM_BROWSER=edge
# 方式B：用浏览器扩展导出的 cookies.txt 文件
# VIDLENS_COOKIES=D:\VidLens\cookies.txt

# 访问 YouTube 的代理（国内必填；Clash 默认 http://127.0.0.1:7890）
# VIDLENS_PROXY=http://127.0.0.1:7890
